          "mode": "raw",
          "raw": "{\n  \"userId\": 1,\n  \"type\": \"ITEM_MATCH\",\n  \"title\": \"Your Lost Item Has a Match!\",\n  \"message\": \"Your Samsung Galaxy S21 has been matched with a found item. The confidence score is 95%. Please review and accept or reject the match.\",\n  \"channel\": \"BOTH\",\n  \"referenceItemId\": 101,\n  \"recipientEmail\": \"john.doe@university.edu\"\n}"
        }
