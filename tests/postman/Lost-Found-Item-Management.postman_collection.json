{
  "info": {
    "name": "Lost-Found Item Management API",
    "description": "Postman collection for testing Item Management endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Item Creation",
      "item": [
        {
          "name": "Create Item - Lost",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Lost Car Keys\",\n  \"description\": \"Silver car keys with keychain\",\n  \"reportType\": \"LOST\",\n  \"category\": \"Electronics\",\n  \"location\": \"Library\",\n  \"imageUrls\": [\n    \"https://example.com/images/lost-keys.jpg\"\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/items?userId={{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "items"
              ],
              "query": [
                {
                  "key": "userId",
                  "value": "{{userId}}"
                }
              ]
            },
            "description": "Create a new LOST item"
          },
          "response": []
        },
        {
          "name": "Create Item - Found",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Found Student ID Card\",\n  \"description\": \"Blue student ID card, name visible\",\n  \"reportType\": \"FOUND\",\n  \"category\": \"Documents\",\n  \"location\": \"Student Center\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/items?userId={{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "items"
              ],
              "query": [
                {
                  "key": "userId",
                  "value": "{{userId}}"
                }
              ]
            },
            "description": "Create a new FOUND item"
          },
          "response": []
        }
      ]
    },
