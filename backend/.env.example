# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/lostfound
DB_USER=postgres
DB_PASSWORD=your_db_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters for HS256
TOKEN_SECRET_KEY=replace_with_a_random_secret_key_at_least_32_chars
TOKEN_EXPIRATION_MS=21600000

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_app_password

# ── Notifications ─────────────────────────────────────────────────────────────
NOTIFICATION_FROM_EMAIL=notifications@lostfound.edu

# ── Rewards ───────────────────────────────────────────────────────────────────
REWARDS_POINTS_PER_FOUND_ITEM=50
REWARDS_POINTS_PER_CLAIMED_ITEM=20
